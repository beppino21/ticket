<?xml version="1.0" encoding="utf-8"?>
<t:layoutdefinition xmlns:t="http://www.captaincasa.com/controllibrary/t" >

<t:beanprocessing id="cp_0" beanbinding="#{d.ChangePasswordUI}" />

<t:rowtitlebar id="cp_1" text="Cambio Password" />

<t:rowbodypane id="cp_10" >

  <t:rowdistance id="cp_11" height="12" />

  <!-- Messaggio di stato (errore o successo) -->
  <t:row id="cp_msg_row" rendered="#{!d.ChangePasswordUI.statusMessage.isEmpty()}" >
    <t:coldistance id="cp_msg_cd" width="16" />
    <t:label id="cp_msg"
        font="#{d.ChangePasswordUI.hasError ? 'color:#cc0000;weight:bold' : 'color:#1a7a1a;weight:bold'}"
        text="#{d.ChangePasswordUI.statusMessage}"
        width="380" />
  </t:row>
  <t:rowdistance id="cp_msg_dist" height="8" />

  <!-- Username (sola lettura, per conferma visiva) -->
  <t:row id="cp_20" coldistance="8" >
    <t:coldistance id="cp_20a" width="16" />
    <t:field id="cp_21" enabled="false" labeltext="Username:" text="#{d.ChangePasswordUI.reqid}" width="220" />
  </t:row>

  <t:rowdistance id="cp_22" height="12" />

  <!-- Password attuale -->
  <t:row id="cp_30" coldistance="8" >
    <t:coldistance id="cp_30a" width="16" />
    <t:password id="cp_31" labeltext="Password attuale:" requestfocus="creation" text="#{d.ChangePasswordUI.vecchiaPassword}" width="220" />
  </t:row>

  <t:rowdistance id="cp_32" height="8" />

  <!-- Nuova password -->
  <t:row id="cp_40" coldistance="8" >
    <t:coldistance id="cp_40a" width="16" />
    <t:password id="cp_41" labeltext="Nuova password:" text="#{d.ChangePasswordUI.nuovaPassword}" width="220" />
  </t:row>

  <t:rowdistance id="cp_42" height="4" />
  <t:row id="cp_hint_row" >
    <t:coldistance id="cp_hint_cd" width="152" />
    <t:label id="cp_hint" font="size:10;color:#888888" text="(minimo 8 caratteri)" />
  </t:row>
  <t:rowdistance id="cp_43" height="8" />

  <!-- Conferma nuova password -->
  <t:row id="cp_50" coldistance="8" >
    <t:coldistance id="cp_50a" width="16" />
    <t:password id="cp_51" labeltext="Conferma password:" text="#{d.ChangePasswordUI.confermaPassword}" width="220" />
  </t:row>

  <t:rowdistance id="cp_60" height="20" />

  <!-- Pulsanti -->
  <t:row id="cp_70" coldistance="8" >
    <t:coldistance id="cp_70a" width="16" />
    <t:button id="cp_71"
        actionListener="#{d.ChangePasswordUI.onCambiaPassword}"
        enabled="#{!d.ChangePasswordUI.success}"
        hotkey="10"
        text="Cambia password"
        width="160" />
    <t:coldistance id="cp_70b" width="12" />
    <t:button id="cp_72"
        actionListener="#{d.ChangePasswordUI.onAnnulla}"
        text="Annulla"
        width="80" />
  </t:row>

  <t:rowdistance id="cp_80" height="16" />

</t:rowbodypane>

</t:layoutdefinition>
